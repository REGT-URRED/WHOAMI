{
  "name": "WHOAMI",
  "version": "2.3.0",
  "backend": "openfang",
  "theme": "neon",
  "colors": {
    "primary": "#00FF88",
    "secondary": "#FF00FF",
    "accent": "#00FFFF",
    "error": "#FF3333",
    "success": "#00FF44",
    "warning": "#FFAA00",
    "info": "#00AAFF",
    "muted": "#444444"
  },
  "agents": {
    "enabled": [
      "architect", "tdd-guide", "code-reviewer", "build-error-resolver",
      "ramon", "e2e-runner", "doc-updater",
      "clip", "lead", "collector", "predictor", "researcher", "twitter", "browser",
      "crawl4ai-scraper", "crawl4ai-deep-crawler", "crawl4ai-extractor",
      "autocode", "autoqa", "autotest", "autofix", "autoreview", "autosec", "autospec",
      "page-agent", "sandbox-agent", "session-agent",
      "agent-reach", "agent-reach-web", "agent-reach-twitter", "agent-reach-youtube",
      "agent-reach-github", "agent-reach-reddit", "agent-reach-rss",
      "frontend-developer", "backend-architect", "product-manager", "ui-designer",
      "ai-engineer", "devops-automator", "security-auditor", "security-reviewer",
      "performance-tester", "data-analyst", "content-strategist"
    ],
    "disabled": ["vega", "refactor-cleaner", "whoami-planner", "whoami-loop"]
  },
  "pipelines": {
    "build": [
      { "agent": "architect" },
      { "agent": "tdd-guide" },
      { "agent": "code-reviewer" },
      { "agent": "build-error-resolver" },
      { "agent": "ramon" },
      { "agent": "e2e-runner" },
      { "agent": "doc-updater" }
    ],
    "fix": [
      { "agent": "build-error-resolver" },
      { "agent": "tdd-guide" },
      { "agent": "code-reviewer" }
    ],
    "refactor": [
      { "agent": "refactor-cleaner" },
      { "agent": "ramon" },
      { "agent": "code-reviewer" }
    ],
    "reverse": [
      { "agent": "reverse-explorer" },
      { "agent": "reverse-hypothesis" },
      { "agent": "reverse-validator" },
      { "agent": "reverse-spec-writer" }
    ],
    "research": [
      { "agent": "researcher" },
      { "agent": "predictor" }
    ],
    "social": [
      { "agent": "twitter" },
      { "agent": "doc-updater" }
    ],
    "intel": [
      { "agent": "collector" },
      { "agent": "researcher" }
    ],
    "autocode": [
      { "agent": "autocode" },
      { "agent": "code-reviewer" }
    ],
    "autotest": [
      { "agent": "autotest" },
      { "agent": "autoqa" }
    ],
    "autofix": [
      { "agent": "autofix" },
      { "agent": "tdd-guide" }
    ],
    "autosec": [
      { "agent": "autosec" },
      { "agent": "security-reviewer" }
    ],
    "research-deep": [
      { "agent": "agent-reach-web" },
      { "agent": "researcher" },
      { "agent": "predictor" }
    ],
    "social-media": [
      { "agent": "agent-reach-twitter" },
      { "agent": "twitter" },
      { "agent": "doc-updater" }
    ],
    "frontend": [
      { "agent": "frontend-developer" },
      { "agent": "ui-designer" }
    ],
    "agency-build": [
      { "agent": "architect" },
      { "agent": "frontend-developer" },
      { "agent": "code-reviewer" }
    ]
  },
  "memory": {
    "enabled": true,
    "backend": "sqlite",
    "path": "~/.whoami/memory.db"
  },
  "autoLearn": true,
  "openfang": {
    "endpoint": "http://127.0.0.1:4200",
    "channels": ["telegram", "slack", "discord", "email"],
    "defaultHands": ["researcher", "browser"]
  },
  "crawl4ai": {
    "mode": "cli",
    "cliPath": "crwl",
    "dockerEndpoint": "http://127.0.0.1:8000",
    "defaultStrategy": "bfs",
    "defaultMaxPages": 10,
    "outputFormat": "markdown",
    "stealth": true
  },
  "autoloop": {
    "mode": "cli",
    "registryPath": "~/.autoloop/registry.jsonl"
  },
  "pageAgent": {
    "model": "qwen3.5-plus",
    "language": "en-US"
  },
  "zero": {
    "permissionMode": "read-only",
    "workspace": "."
  },
  "agentReach": {
    "platforms": ["web", "twitter", "github", "youtube", "reddit", "rss"]
  }
}
